# hack_it — example environment variables.
# Copy to `.env` (already gitignored) and fill in values.

# ──────────────────────────────────────────────────────────────────────────────
# Anthropic API — the hackathon's named sponsored tool.
# Rules.md §1.2 exempts this from the OSI-only dependency rule.
# Get from https://console.anthropic.com/ → API Keys.
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────────────────────────────────────────
# UMLS Terminology Services — optional.
# Used ONLY for substrate-side live concept lookups (e.g. hover definitions in
# the UI, CUI normalisation for claim rendering). NOT required for MEDCON eval;
# MEDCON uses QUICKUMLS_PATH (below).
# Sign up at https://uts.nlm.nih.gov/uts/signup-login (requires Metathesaurus
# Licence; academic .edu addresses approve fastest).
UMLS_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# MEDCON concept-extractor selection (see docs/decisions/2026-04-21_medcon-tiered-fallback.md).
# Valid values: scispacy (T1, default) | quickumls (T0) | null (T2)

# T1 default — no UMLS licence needed. Active on `./scripts/install_scispacy.sh`.
CONCEPT_EXTRACTOR=scispacy
SCISPACY_MODEL=en_core_sci_lg

# T0 upgrade — activates when UMLS licence is approved AND QuickUMLS index is built.
# See scripts/install_umls.sh. Pinned to UMLS 2025AB Level 0 Subset.
# Uncomment + set:
# CONCEPT_EXTRACTOR=quickumls
# QUICKUMLS_PATH=/absolute/path/to/quickumls_index

# T2 hard fallback — MEDCON column omitted; pipeline reports ROUGE + BERTScore + BLEURT only,
# plus section-level ROUGE and MedEinst Bias Trap Rate as supplementary signals.
# CONCEPT_EXTRACTOR=null

# ──────────────────────────────────────────────────────────────────────────────
# Eval judges — pinned model IDs for reproducibility (rules.md §6.3 methodology honesty).
# Do not change without updating docs/decisions/ + the relevant eval LIMITATIONS.md.
DDXPLUS_JUDGE_MODEL=gpt-4o-2024-08-06
LONGMEMEVAL_JUDGE_MODEL=gpt-4o-2024-08-06

# ──────────────────────────────────────────────────────────────────────────────
# Local runtime settings
# LOG_LEVEL=INFO                  # structlog level; DEBUG for dev, INFO for eval
# DEMO_SEED=42                    # scripts/run_demo.sh determinism seed
